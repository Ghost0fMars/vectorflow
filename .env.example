# PORT: Port d'écoute de l'application Node.js (défaut : 5000).
PORT="5000"

# === OLLAMA CONFIGURATION ===
# USE_OLLAMA: Activer l'intégration native d'Ollama au lieu du serveur Python (true/false)
USE_OLLAMA="true"

# OLLAMA_URL: URL du serveur Ollama local
OLLAMA_URL="http://localhost:11434"

# OLLAMA_EMBED_MODEL: Modèle d'embeddings utilisé par Ollama (ex: nomic-embed-text)
OLLAMA_EMBED_MODEL="nomic-embed-text:latest"

# OLLAMA_CHAT_MODEL: Modèle de chat pour le résumé/RAG (ex: gemma3:12b, qwen3:14b, llama3)
OLLAMA_CHAT_MODEL="gemma3:12b"

# === SERVEUR PYTHON EMBEDDINGS (FALLBACK) ===
# EMBED_LLM_URL: URL du serveur Python d'embeddings (si USE_OLLAMA est false).
EMBED_LLM_URL="http://localhost:8001"

# EMBED_MODEL: Modèle utilisé par embed_server.py pour générer les vecteurs.
EMBED_MODEL="intfloat/multilingual-e5-base"

# === CONFIGURATION VECTORIELLE ===
# EMBED_VECTOR_SIZE: Dimension des vecteurs Qdrant (doit correspondre au modèle).
# nomic-embed-text ou multilingual-e5-base → 768
EMBED_VECTOR_SIZE="768"

# === CONFIGURATION QDRANT ===
# QDRANT_URL: URL de l'instance Qdrant.
QDRANT_URL="http://localhost:6333"

# QDRANT_API_KEY: Uniquement pour Qdrant Cloud (laisser vide en local).
QDRANT_API_KEY=""
