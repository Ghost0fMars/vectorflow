# PORT: Port d'écoute de l'application Node.js (défaut : 5000).
PORT="5000"

# EMBED_LLM_URL: URL du serveur Python d'embeddings (embed_server.py).
# Démarrer avec : python3 embed_server.py
EMBED_LLM_URL="http://localhost:8001"

# EMBED_MODEL: Modèle utilisé par embed_server.py pour générer les vecteurs.
# intfloat/multilingual-e5-base → 768 dims, bon support français/multilingue.
# intfloat/multilingual-e5-large → 1024 dims, meilleure qualité, plus lent.
EMBED_MODEL="intfloat/multilingual-e5-base"

# EMBED_VECTOR_SIZE: Dimension des vecteurs Qdrant (doit correspondre au modèle).
# multilingual-e5-base → 768 | multilingual-e5-large → 1024
EMBED_VECTOR_SIZE="768"

# QDRANT_URL: URL de l'instance Qdrant.
QDRANT_URL="http://localhost:6333"

# QDRANT_API_KEY: Uniquement pour Qdrant Cloud (laisser vide en local).
QDRANT_API_KEY=""
